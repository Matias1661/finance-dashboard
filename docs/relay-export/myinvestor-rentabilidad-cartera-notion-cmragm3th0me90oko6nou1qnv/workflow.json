        "steps": [
          {
            "stepId": "trigger",
            "stepType": "gmail.mailReceived",
            "title": "Email de MyInvestor",
            "description": "Checks connection periodically and starts run for detected events. Event is automatically detected, concrete implementation depends on integration. Filters are optional and can be used to further limit which events should trigger runs. Can only trigger once per Email.",
            "connection": "matiaso81@gmail.com (owned by Matias Ortiz)",
            "inputs": [
              {
                "input": "filter",
                "$ref": "relay/filter",
                "value": {
                  "or": [
                    {
                      "and": [
                        {
                          "field": "From",
                          "operator": "equalOneOf",
                          "value": [
                            "comunicaciones@myinvestor.es",
                            "notificaciones@myinvestor.es"
                          ]
                        },
                        {
                          "field": "Subject",
                          "operator": "contains",
                          "value": "Rentabilidad de tu cartera en"
                        }
                      ]
                    }
                  ]
                }
              },
              {
                "input": "onlyFirst",
                "title": "Only trigger for first email in conversation",
                "type": "boolean",
                "value": false
              }
            ],
            "effectiveOutputSchema": {
              "$ref": "#/resource-types/gmail.mail"
            }
          },
          {
            "stepId": "w9mv1p",
            "stepType": "ai.prompt.object",
