              {
                "input": "filter",
                "$ref": "relay/filter",
                "value": {
                  "or": [
                    {
                      "and": [
                        {
                          "field": "From",
                          "operator": "equal",
                          "value": "beatriz.matos@luzagroup.com"
                        },
                        {
                          "field": "Attachments",
                          "operator": "notEmpty",
                          "value": null
                        }
                      ]
                    }
                  ]
                }
              },
              {
                "input": "onlyFirst",
                "title": "Only trigger for first email in conversation",
                "type": "boolean",
                "value": false
